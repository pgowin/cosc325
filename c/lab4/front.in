REM A:2,B:3
CLEAR
10 INPUT A,B
20 LET C = A + B
30 LET D = B - A
40 LET E = A * B
50 LET F = B / A
60 IF A < B THEN GOTO 70
70 IF B > A THEN LET G = E
80 IF A = A THEN LET H = F
90 IF A <= B THEN LET I = D
100 IF B >= A THEN LET J = C
110 IF A <> 0 THEN GOSUB 200
120 PRINT A, B, C, D, E, F
130 PRINT G, H, I, J, K
140 END
200 LET K = A + B + C
210 RETURN
RUN